{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "bargauge", "name": "Bar gauge", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "CertStream CT log collector – full operational overview",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100, "title": "📊 Throughput", "type": "row" },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "cps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1, "options": { "legend": { "calcs": ["mean","max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Certificates parsed / sec (by log)",
      "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "sum by (log_url) (rate(ct_certs_parsed_total[$__rate_interval]))", "legendFormat": "{{log_url}}", "refId": "A" }
      ]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "cps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2, "options": { "legend": { "calcs": ["mean","max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Certificates written to ClickHouse / sec (by log)",
      "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "sum by (log_url) (rate(ct_certs_written_total[$__rate_interval]))", "legendFormat": "{{log_url}}", "refId": "A" }
      ]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "title": "Entries fetched / sec (by log)",
      "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "sum by (log_url) (rate(ct_entries_fetched_total[$__rate_interval]))", "legendFormat": "{{log_url}}", "refId": "A" }
      ]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 4,
      "title": "Certificates by entry type / sec",
      "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "sum by (ct_entry_type) (rate(ct_certs_parsed_total[$__rate_interval]))", "legendFormat": "{{ct_entry_type}}", "refId": "A" }
      ]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 101, "title": "🪵 Per-Log Progress & Backlog", "type": "row" },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short", "custom": { "lineWidth": 1 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "id": 5,
      "title": "Log progress index (entries collected)",
      "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "ct_log_progress_index", "legendFormat": "{{log_url}}", "refId": "A" }
      ]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "id": 6,
      "title": "Log backlog (entries remaining)",
      "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "ct_log_backlog_entries", "legendFormat": "{{log_url}}", "refId": "A" }
      ]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1000000 },
            { "color": "red", "value": 10000000 }
          ]},
          "unit": "short",
          "mappings": []
        }, "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 },
      "id": 7,
      "title": "Backlog per log (current)",
      "type": "bargauge",
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "ct_log_backlog_entries", "legendFormat": "{{log_url}}", "refId": "A" }
      ]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "id": 102, "title": "🌐 HTTP Fetching", "type": "row" },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 35 },
      "id": 8,
      "title": "Fetch requests / sec",
      "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "sum by (log_url, fetch_type) (rate(ct_fetch_requests_total[$__rate_interval]))", "legendFormat": "{{log_url}} {{fetch_type}}", "refId": "A" }
      ]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 35 },
      "id": 9,
      "title": "Fetch errors / sec (by status code)",
      "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "sum by (log_url, status_code) (rate(ct_fetch_errors_total[$__rate_interval]))", "legendFormat": "{{log_url}} {{status_code}}", "refId": "A" }
      ]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "Bps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 35 },
      "id": 10,
      "title": "Bytes received / sec (by log)",
      "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "sum by (log_url) (rate(ct_fetch_bytes_total[$__rate_interval]))", "legendFormat": "{{log_url}}", "refId": "A" }
      ]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "s", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 43 },
      "id": 11,
      "title": "HTTP fetch latency p50/p95/p99 (rfc6962)",
      "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.50, sum by (le) (rate(ct_fetch_duration_seconds_bucket{fetch_type=\"rfc6962\"}[$__rate_interval])))", "legendFormat": "p50", "refId": "A" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.95, sum by (le) (rate(ct_fetch_duration_seconds_bucket{fetch_type=\"rfc6962\"}[$__rate_interval])))", "legendFormat": "p95", "refId": "B" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.99, sum by (le) (rate(ct_fetch_duration_seconds_bucket{fetch_type=\"rfc6962\"}[$__rate_interval])))", "legendFormat": "p99", "refId": "C" }
      ]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "s", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 43 },
      "id": 12,
      "title": "HTTP fetch latency p50/p95/p99 (tiled)",
      "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.50, sum by (le) (rate(ct_fetch_duration_seconds_bucket{fetch_type=~\"tiled.*\"}[$__rate_interval])))", "legendFormat": "p50", "refId": "A" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.95, sum by (le) (rate(ct_fetch_duration_seconds_bucket{fetch_type=~\"tiled.*\"}[$__rate_interval])))", "legendFormat": "p95", "refId": "B" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.99, sum by (le) (rate(ct_fetch_duration_seconds_bucket{fetch_type=~\"tiled.*\"}[$__rate_interval])))", "legendFormat": "p99", "refId": "C" }
      ]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 51 },
      "id": 103, "title": "⚙️ Parse Pipeline", "type": "row" },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 52 },
      "id": 13,
      "title": "Parse latency p50/p95/p99 (by format)",
      "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.50, sum by (le, format) (rate(ct_parse_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p50 {{format}}", "refId": "A" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.95, sum by (le, format) (rate(ct_parse_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p95 {{format}}", "refId": "B" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.99, sum by (le, format) (rate(ct_parse_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p99 {{format}}", "refId": "C" }
      ]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 52 },
      "id": 14,
      "title": "Parse errors / sec (by format)",
      "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "sum by (log_url, format) (rate(ct_parse_errors_total[$__rate_interval]))", "legendFormat": "{{log_url}} {{format}}", "refId": "A" }
      ]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 52 },
      "id": 15,
      "title": "Avg batch / tile size (entries)",
      "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "rate(ct_parse_batch_size_entries_sum[$__rate_interval]) / rate(ct_parse_batch_size_entries_count[$__rate_interval])", "legendFormat": "avg batch size", "refId": "A" }
      ]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 60 },
      "id": 104, "title": "🗄️ Queue Depths & Workers", "type": "row" },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 32 },
            { "color": "red", "value": 56 }
          ]}, "unit": "short", "min": 0, "max": 64 }, "overrides": [] },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 61 },
      "id": 16,
      "title": "Parse queue depth",
      "type": "gauge",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "ct_parse_queue_depth", "refId": "A" }
      ]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 16 },
            { "color": "red", "value": 28 }
          ]}, "unit": "short", "min": 0, "max": 32 }, "overrides": [] },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 61 },
      "id": 17,
      "title": "Write queue depth",
      "type": "gauge",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "ct_write_queue_depth", "refId": "A" }
      ]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
            { "color": "blue", "value": null }
          ]}, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 61 },
      "id": 18,
      "title": "Active collector tasks",
      "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "ct_active_collector_tasks", "refId": "A" }
      ]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
            { "color": "blue", "value": null }
          ]}, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 61 },
      "id": 19,
      "title": "Parser workers",
      "type": "stat",
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "ct_active_parser_workers", "refId": "A" }
      ]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 67 },
      "id": 20,
      "title": "Queue depths over time",
      "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "ct_parse_queue_depth", "legendFormat": "parse queue", "refId": "A" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "ct_write_queue_depth", "legendFormat": "write queue", "refId": "B" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "ct_cert_writer_pending", "legendFormat": "cert writer buffer", "refId": "C" }
      ]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 75 },
      "id": 105, "title": "🗃️ Database", "type": "row" },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 76 },
      "id": 21,
      "title": "CertWriter flush latency p50/p95/p99",
      "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.50, sum by (le) (rate(ct_db_cert_write_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p50", "refId": "A" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.95, sum by (le) (rate(ct_db_cert_write_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p95", "refId": "B" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.99, sum by (le) (rate(ct_db_cert_write_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p99", "refId": "C" }
      ]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 76 },
      "id": 22,
      "title": "SliceWriter flush latency p50/p95",
      "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.50, sum by (le) (rate(ct_db_slice_write_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p50", "refId": "A" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.95, sum by (le) (rate(ct_db_slice_write_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p95", "refId": "B" }
      ]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 76 },
      "id": 23,
      "title": "get_pending_slices latency p50/p95",
      "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.50, sum by (le) (rate(ct_db_get_slices_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p50", "refId": "A" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "histogram_quantile(0.95, sum by (le) (rate(ct_db_get_slices_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p95", "refId": "B" }
      ]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 84 },
      "id": 24,
      "title": "DB errors / sec (by operation)",
      "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "sum by (operation) (rate(ct_db_errors_total[$__rate_interval]))", "legendFormat": "{{operation}}", "refId": "A" }
      ]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 84 },
      "id": 25,
      "title": "CertWriter batch size distribution",
      "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "rate(ct_db_cert_write_batch_size_rows_sum[$__rate_interval]) / rate(ct_db_cert_write_batch_size_rows_count[$__rate_interval])", "legendFormat": "avg rows/flush", "refId": "A" }
      ]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 4 },
            { "color": "red", "value": 8 }
          ]}, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 84 },
      "id": 26,
      "title": "DB connection pool",
      "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "ct_db_pool_checked_out", "legendFormat": "checked out", "refId": "A" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "ct_db_pool_overflow", "legendFormat": "overflow", "refId": "B" }
      ]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 92 },
      "id": 27,
      "title": "Slices created / sec",
      "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "sum by (log_id) (rate(ct_slices_created_total[$__rate_interval]))", "legendFormat": "{{log_id}}", "refId": "A" }
      ]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 92 },
      "id": 28,
      "title": "Slice progress rows written / sec",
      "type": "timeseries",
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "rate(ct_slice_progress_rows_total[$__rate_interval])", "legendFormat": "rows/s", "refId": "A" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "rate(ct_slice_progress_flushes_total[$__rate_interval])", "legendFormat": "flushes/s", "refId": "B" }
      ]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 100 },
      "id": 106, "title": "🔒 Certificate Intelligence", "type": "row" },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 101 },
      "id": 29,
      "title": "Top 10 issuers (certs / sec)",
      "type": "bargauge",
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient"
      },
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "topk(10, sum by (issuer) (rate(ct_certs_by_issuer_total[$__rate_interval])))", "legendFormat": "{{issuer}}", "refId": "A" }
      ]
    },

    { "datasource": "${DS_PROMETHEUS}",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }, "overrides": [] },
