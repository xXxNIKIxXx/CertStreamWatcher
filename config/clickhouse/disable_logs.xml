<!-- /etc/clickhouse-server/config.d/disable_logs.xml -->
<clickhouse>
    <query_log remove="1"/>
    <trace_log remove="1"/>
    <query_thread_log remove="1"/>
    <processors_profile_log remove="1"/>
    <part_log remove="1"/>
    <metric_log remove="1"/>
    <asynchronous_metric_log remove="1"/>
    <query_metric_log remove="1"/>
    <text_log remove="1"/>
</clickhouse>